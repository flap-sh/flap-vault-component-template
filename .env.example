# Optional override-only config.
# The template runs without a local env file. Set values here only when you
# want to replace the built-in defaults.
#
# Optional: override the runtime host proxy target.
# Defaults to https://flap.sh.
FLAP_RUNTIME_HOST_ORIGIN=

# Optional: no-secret oracle provisioning for local preview/runtime hosts.
# Flap runtime does not hold or forward upstream Authorization tokens. If an
# upstream feed requires auth, expose your own reviewed no-secret HTTPS relay.
# fixedParams are enforced by the runtime and cannot be overridden by UI params.
# FLAP_RUNTIME_ORACLE_REGISTRY={"example-feed":{"endpoint":"https://oracle.example.com/feed","fixedParams":{"feed":"example"},"allowedParams":["matchId"]}}

# If wallet connection is rate-limited, create your own Reown/WalletConnect
# Project ID and set it here:
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional local RPC overrides for preview.
# Use these only if your network or public RPC limits make the default BNB
# Chain preview transport unstable. Comma-separated fallback URLs are supported:
NEXT_PUBLIC_BSC_RPC_URL=
NEXT_PUBLIC_BSC_TESTNET_RPC_URL=
